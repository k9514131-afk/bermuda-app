root = "."
output_dir = "public"

[[redirects]]
from = "/*"
to = "/index.html"
status = 200

[[build]]
command = "npm run build"
functions = "api"

[build.environment]
NODE_VERSION = "20"

[[headers]]
for = "/_next/static/*"
[headers.values]
Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
for = "/*.js"
[headers.values]
Cache-Control = "public, max-age=3600"

[[headers]]
for = "/*.html"
[headers.values]
Cache-Control = "no-cache, no-store, must-revalidate"
